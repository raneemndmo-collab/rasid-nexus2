{
  "moduleId": "M13",
  "name": "File Manager",
  "version": "1.0.0",
  "phase": 2,
  "type": "business",
  "database": "m13_files_db",
  "namespace": "file.*",
  "dependencies": ["K1", "K2", "K3", "K5", "K8"],
  "events_published": [
    "file.uploaded",
    "file.downloaded",
    "file.deleted",
    "file.shared",
    "file.moved",
    "file.folder.created",
    "file.folder.deleted"
  ],
  "events_consumed": ["storage.object.uploaded", "storage.object.deleted"],
  "apis": [
    "POST /m13/files",
    "GET /m13/files",
    "GET /m13/files/folder/:folderId",
    "GET /m13/files/tag/:tag",
    "GET /m13/files/:id",
    "PUT /m13/files/:id/move",
    "DELETE /m13/files/:id",
    "POST /m13/files/folders",
    "GET /m13/files/folders/list",
    "DELETE /m13/files/folders/:id",
    "POST /m13/files/:id/share",
    "GET /m13/files/:id/shares"
  ]
}
