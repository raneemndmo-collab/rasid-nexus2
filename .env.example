# ═══ Rasid Platform — Environment Variables ═══

# ─── Application ───
NODE_ENV=development
PORT=3000

# ─── JWT (K1 Auth Gateway) ───
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=86400

# ─── PostgreSQL Databases ───
# K1 Auth DB
K1_DB_HOST=localhost
K1_DB_PORT=5432
K1_DB_NAME=k1_auth_db
K1_DB_USER=k1_user
K1_DB_PASSWORD=change-me

# K2 Tenant DB
K2_DB_HOST=localhost
K2_DB_PORT=5432
K2_DB_NAME=k2_tenant_db
K2_DB_USER=k2_user
K2_DB_PASSWORD=change-me

# K3 Audit DB
K3_DB_HOST=localhost
K3_DB_PORT=5432
K3_DB_NAME=k3_audit_db
K3_DB_USER=k3_user
K3_DB_PASSWORD=change-me

# K4 Config DB
K4_DB_HOST=localhost
K4_DB_PORT=5432
K4_DB_NAME=k4_config_db
K4_DB_USER=k4_user
K4_DB_PASSWORD=change-me

# K5 Events DB
K5_DB_HOST=localhost
K5_DB_PORT=5432
K5_DB_NAME=k5_events_db
K5_DB_USER=k5_user
K5_DB_PASSWORD=change-me

# M1 Auth Users DB
M1_DB_HOST=localhost
M1_DB_PORT=5432
M1_DB_NAME=m1_auth_users_db
M1_DB_USER=m1_user
M1_DB_PASSWORD=change-me

# M2 Tenants DB
M2_DB_HOST=localhost
M2_DB_PORT=5432
M2_DB_NAME=m2_tenants_db
M2_DB_USER=m2_user
M2_DB_PASSWORD=change-me

# M3 Roles DB
M3_DB_HOST=localhost
M3_DB_PORT=5432
M3_DB_NAME=m3_roles_db
M3_DB_USER=m3_user
M3_DB_PASSWORD=change-me

# M4 Permissions DB
M4_DB_HOST=localhost
M4_DB_PORT=5432
M4_DB_NAME=m4_permissions_db
M4_DB_USER=m4_user
M4_DB_PASSWORD=change-me

# M30 Actions DB
M30_DB_HOST=localhost
M30_DB_PORT=5432
M30_DB_NAME=m30_actions_db
M30_DB_USER=m30_user
M30_DB_PASSWORD=change-me

# ─── Redis (K4 Config Cache) ───
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me

# ─── Kafka / NATS (K5 Event Bus) ───
KAFKA_BROKERS=localhost:9092
NATS_URL=nats://localhost:4222

# ─── Monitoring ───
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
